# Copie para prisma/.env (não commite o ficheiro real).
# Usado pela CLI do Prisma: migrate, generate, studio.
#
#   Copy-Item prisma/.env.example prisma/.env
#
# URL abaixo = defaults do docker-compose.yml (POSTGRES_USER/PASSWORD/DB = flow).
DATABASE_URL=postgresql://flow:flow@localhost:5432/flow?schema=public

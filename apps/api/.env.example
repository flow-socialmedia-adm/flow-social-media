# Copie para apps/api/.env (não commite o ficheiro real).
#
#   Copy-Item apps/api/.env.example apps/api/.env
#
# Valores mínimos abaixo alinham-se ao docker compose padrão do repositório
# (utilizador/senha/db: flow / flow / flow). Ajuste se mudar o Postgres.

NODE_ENV=development
PORT=3000

DATABASE_URL=postgresql://flow:flow@localhost:5432/flow?schema=public

# Obrigatórios na API (mínimo 16 caracteres cada — ver validação em app.module)
JWT_ACCESS_SECRET=change-me-access-secret-min-16-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-min-16

JWT_ACCESS_EXPIRES=900s
JWT_REFRESH_EXPIRES=7d

# Origens CORS separadas por vírgula (ex.: http://localhost:5173,http://127.0.0.1:5173)
CORS_ORIGINS=http://localhost:5173

# URL do app (links de convite e reset de senha nos e-mails / logs em dev)
FRONTEND_URL=http://localhost:5173

# Opcional: login Google (deve coincidir com VITE_GOOGLE_CLIENT_ID no frontend)
GOOGLE_CLIENT_ID=

# Câmbio (o código tem default se omitir)
FX_BASE_URL=https://api.exchangerate.host

# Uploads (S3 ou compatível). Deixe vazio para desenvolvimento sem object storage.
S3_ENDPOINT=
S3_REGION=auto
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET=

# Base64 de 32 bytes para encriptação de credenciais (deixe vazio se não usar a feature)
CREDENTIALS_ENCRYPTION_KEY=

# Apenas desenvolvimento: seed ao arrancar (ver dev.seed.service)
SEED_DEV=false
